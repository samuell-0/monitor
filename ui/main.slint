import { Button, VerticalBox, Slider, HorizontalBox, GridBox, TextEdit } from "std-widgets.slint";

component _Time {
    Rectangle {
        background: #1a1a2e80;
        border-radius: 16px;
        border-width: 1px;
        border-color: #00fff780;
        drop-shadow-blur: 30px;
        drop-shadow-color: #00fff740;
        drop-shadow-offset-y: 0px;

        VerticalBox {
            padding: 0px;
            alignment: center;
            
            Text {
                text: "4:13AM";
                color: #00fff7;
                font-size: 32px;
                font-weight: 300;
                horizontal-alignment: center;
            }
            
            Text {
                text: "Sunday, April 26";
                color: #ffffff80;
                font-size: 12px;
                font-weight: 300;
                horizontal-alignment: center;
            }
        }
    }
}

component _Graph inherits Rectangle {
    in property <image> image;
    in property <string> label: "USAGE";
    in property <string> value: "0%";
    in property <color> accent-color: #00fff7;

    background: #16213e60;
    border-radius: 20px;
    border-width: 1px;
    border-color: root.accent-color.with-alpha(0.6);
    drop-shadow-blur: 25px;
    drop-shadow-color: root.accent-color.with-alpha(0.3);
    drop-shadow-offset-y: 0px;

    VerticalBox {
        padding: 5px;
        spacing: 0px;

        HorizontalBox {
            alignment: space-between;

            Text {
                text: root.label;
                color: #ffffff90;
                font-size: 10px;
                font-weight: 600;
                letter-spacing: 2px;
            }

            Text {
                text: root.value;
                color: root.accent-color;
                font-size: 10px;
                font-weight: 300;
            }
        }

        Rectangle {
            background: #0a0e1b80;
            border-radius: 14px;
            border-width: 1px;
            border-color: root.accent-color.with-alpha(0.4);
            clip: true;

            Image {
                source: root.image;
                width: parent.width;
                height: parent.height;
                image-fit: fill;
                opacity: 0.8;
            }

            Rectangle {
                background: @linear-gradient(180deg, transparent 60%, root.accent-color.with-alpha(0.3) 100%);
            }
        }
    }
}

component _Slide inherits Rectangle {
    background: #16213e60;
    border-radius: 20px;
    border-width: 1px;
    border-color: #ff006e60;
    drop-shadow-blur: 25px;
    drop-shadow-color: #ff006e30;
    drop-shadow-offset-y: 0px;

    height: 150px;

    VerticalBox {
        padding: 20px;
        spacing: 10px;

        VerticalBox {
            spacing: 0px;
            padding: 0px;
            HorizontalBox {
                padding: 0px;
                alignment: space-between;
                
                Text {
                    text: "BRIGHTNESS";
                    color: #ffffff90;
                    font-size: 10px;
                    font-weight: 600;
                    letter-spacing: 2px;
                }
                
                Text {
                    text: "75%";
                    color: #ff006e;
                    font-size: 14px;
                    font-weight: 300;
                }
            }

            Slider {
                value: 75;
                maximum: 100;
                minimum: 0;
            }
        }
        
        VerticalBox {
            spacing: 0px;
            padding: 0px;
            
            HorizontalBox {
                padding: 0px;
                alignment: space-between;
                
                Text {
                    text: "OPACITY";
                    color: #ffffff90;
                    font-size: 10px;
                    font-weight: 600;
                    letter-spacing: 2px;
                }
                
                Text {
                    text: "85%";
                    color: #ff006e;
                    font-size: 14px;
                    font-weight: 300;
                }
            }

            Slider {
                value: 85;
                maximum: 100;
                minimum: 0;
            }
        }
    }
}

component _Bottons inherits Rectangle {

        in property <string> name;
        in property <color> _color_1: #ff006e;
        in property <color> _color_2: #ff006e;

        in property <float> d;

        background: @linear-gradient(135deg, _color_1 0%, _color_2 100%);
        border-radius: 14px;
        border-width: 1px;
        border-color: #ffffff40;
        drop-shadow-blur: 20px;
        drop-shadow-color: #ff006e50;

        TouchArea {
            clicked => { 
                if (d <= 0.5)
                {
                    // animation-tick()->
                }
             }
        }

        VerticalBox {
            alignment: center;
            spacing: 0px;
            padding: 0px;

            Text {
                text: "󰓅";
                font-size: 20px;
                color: #ffffff;
                horizontal-alignment: center;
            }

            Text {
                text: root.name;
                color: #ffffffd0;
                font-size: 9px;
                font-weight: 600;
                letter-spacing: 1.5px;
                horizontal-alignment: center;
            }
        }
}
component dynamic_widgets inherits Rectangle {
        in-out property <float> _horizontal_stretch;

        background: #16213e60;
        border-radius: 20px;
        border-width: 1px;
        border-color: #8338ec60;
        drop-shadow-blur: 25px;
        drop-shadow-color: #8338ec30;
        drop-shadow-offset-y: 0px;

        GridLayout {
            spacing: 5px;
            padding: 5px;
            Button {
                text: "touch me lol";
                clicked => {
                    _horizontal_stretch += 30;
                }

            }
            _Bottons {
                _color_1: #6989aa;
                _color_2: #898959;
            }
            // _Bottons {
            //     _color_1: #6989aa;
            //     _color_2: #1f1932;
            // }
        }
}
component  terminal_emulator inherits Rectangle {
    height: 40px;
    background: #16213e60;
    border-radius: 16px;
    border-width: 1px;
    border-color: #00fff760;
    drop-shadow-blur: 25px;
    drop-shadow-color: #00fff730;
    HorizontalBox {
        padding: 5px;
        spacing: 12px;
        horizontal-stretch: 1;

        Text {
            text: "$";
            color: #00fff7;
            font-size: 15px;
            font-weight: 300;
            vertical-alignment: center;
        }

        TextInput {
            horizontal-stretch: 0.9;
            text: "neofetch";
            font-size: 13px;
            color: #ffffffd0;
            vertical-alignment: center;
            horizontal-alignment: left;
        }
    }
}
export component AppWindow inherits Window {
    in property <image> cpu_usage;
    in property <image> mem_usage;

    in-out property <float> _horizontal_stretch: 0.3;

    full-screen: false;
    no-frame: true;
    width: 800px;
    height: 500px;
    
    callback request-increase-value();

    Rectangle {
        Image {
            source: @image-url("../resources/3.jpg");
            width: parent.width;
            height: parent.height;
            image-fit: cover;
        }
        
        // Blur overlay
        Rectangle {
            background: #181f387d;
        }

        VerticalBox {
            padding: 20px;
            spacing: 24px;

            HorizontalBox {
                spacing: 28px;

                VerticalBox {
                    // horizontal-stretch: 0.6;
                    width: parent.width * 0.5;
                    spacing: 10px;

                    _Time {}
                    
                    _Graph {
                        image: @image-url("../resources/d.png");
                        label: "CPU";
                        value: "67%";
                        accent-color: #00fff7;
                    }
                    _Graph {
                        image: @image-url("../resources/d.png");
                        label: "MEMORY";
                        value: "8.2GB";
                        accent-color: #00fff7;
                    }
                }
                
                VerticalBox {
                    spacing: 12px;
                    _Slide {}
                    dynamic_widgets{}
                }
            }
            terminal-emulator {}
        }
    }
}